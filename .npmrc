# Next.js 16 shipped Oct 2025. Several packages (Sentry, etc.) haven't updated
# their peer dependency declarations to include ^16 yet even though they work.
# legacy-peer-deps restores the npm v6 resolver behaviour — uses the package
# if it's functionally compatible, ignores undeclared peer dep ranges.
# Remove this line once upstream packages declare Next.js 16 support.
legacy-peer-deps=true
